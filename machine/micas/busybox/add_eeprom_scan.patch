diff --git a/miscutils/sys_eeprom_i2c.c b/miscutils/sys_eeprom_i2c.c
index be7fe07..014ef45 100644
--- a/miscutils/sys_eeprom_i2c.c
+++ b/miscutils/sys_eeprom_i2c.c
@@ -1,3 +1,4 @@
+#include<stdlib.h>
 #include "libbb.h"
 #include "onie_tlvinfo.h"
 #include "sys_eeprom.h"
@@ -10,6 +11,32 @@
 #else
     #define EEPROM_TYPE EEPROM_TYPE_UNKNOWN
 #endif
+int get_syseeprom_by_cfg(struct eeprom *e)
+{
+    FILE * fp;
+    char bus[10]={0};
+    char addr[10]={0};
+    char eeprom_bus[20]={0};
+
+    fp = popen("cat /etc/syseeprom.conf | grep onie_syseeprom_bus |grep -Eo '[0-9]+'","r");
+    fgets(bus,sizeof(bus),fp);
+    pclose(fp);
+
+    fp = popen("cat /etc/syseeprom.conf | grep onie_syseeprom_addr |grep -Eo '0x[0-9]+'","r");
+    fgets(addr,sizeof(addr),fp);
+    pclose(fp);
+
+    if ( strlen(bus) < 2 || strlen(addr) < 2 ){
+        return -1;
+    }
+    /* remove \n */
+    bus[ strlen(bus) - 1 ] = 0;
+    addr[ strlen(addr) - 1 ] = 0;
+
+    sprintf(eeprom_bus,"/dev/i2c-%s",bus);
+    return  eeprom_open(eeprom_bus, strtol(addr, NULL, 16),
+                    EEPROM_TYPE, e);
+}
 
