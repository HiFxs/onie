+
+#define C3000_P2SB_DW0_PMODE_MASK               (0x1c00)
+#define C3000_P2SB_DW0_RX_EN_MASK               (0x200)
+#define C3000_P2SB_DW0_TX_EN_MASK               (0x100)
+
+struct p2sb_regs {
+	u32	pad_cfg_dw0;
+	u32	pad_cfg_dw1;
+};
+
+/* Specifies number of GPIO PINS */
+#define C3000_GPIO_PINS_NUMS        (147)
+/**
+ * struct p2sb_gpio_reg_data - The register store data.
+ * @ien_reg:	To store contents of IEN register.
+ * @imask_reg:	To store contents of IMASK register.
+ * @po_reg:	To store contents of PO register.
+ * @pm_reg:	To store contents of PM register.
+ * @im0_reg:	To store contents of IM0 register.
+ * @im1_reg:	To store contents of IM1 register.
+ * @gpio_use_sel_reg : To store contents of GPIO_USE_SEL register.
+ *		       (Only ML7223 Bus-n)
+ */
+struct p2sb_gpio_reg_data {
+	u32 pad_cfg_dw0;
+	u32 pad_cfg_dw1;
+};
+
+/**
+ * struct p2sb_gpio - GPIO private data structure.
+ * @base:			PCI base address of Memory mapped I/O register.
+ * @reg:			Memory mapped p2sb GPIO register list.
+ * @dev:			Pointer to device structure.
+ * @gpio:			Data for GPIO infrastructure.
+ * @p2sb_gpio_reg:		Memory mapped Register data is saved here
+ *				when suspend.
+ * @lock:			Used for register access protection
+ * @irq_base:		Save base of IRQ number for interrupt
+ * @ioh:		IOH ID
+ * @spinlock:		Used for register access protection
+ */
+struct p2sb_gpio {
+	void __iomem *base;
+	struct p2sb_regs __iomem *reg;
+	struct device *dev;
+	struct gpio_chip gpio;
+	struct p2sb_gpio_reg_data p2sb_gpio_reg;
+	int irq_base;
+	spinlock_t spinlock;
+};
+
+typedef struct p2sb_gpio_nr_map_s {
+    int nr;
+    int gpio;
+    int dw_base;
+} p2sb_gpio_nr_map_t;
+
+/****************** i2c adapter with gpio ***********************/
+#define GPIO_SDA        (44)
+#define GPIO_SCL        (45)
+
+#if 0
