+static void i2c_gpio_release(struct device *dev)
+{
+    return;
+}
+
+static struct platform_device i2c_gpio = {
+    .name           = "i2c-gpio",
+    .num_resources  = 0,
+    .id             = -1,
+    
+    .dev = {
+        .platform_data = &i2c_pdata,
