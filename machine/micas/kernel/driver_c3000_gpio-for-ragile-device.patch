+    }
+};
+
+static p2sb_gpio_nr_map_t g_p2sb_gpio_map[] = {
+    {.nr = 4, .gpio = -1, .dw_base = 0xc50568},
+    {.nr = 5, .gpio = -1, .dw_base = 0xc50570},
+    {.nr = 6, .gpio = -1, .dw_base = 0xc50578},
+    {.nr = 7, .gpio = -1, .dw_base = 0xc50580},
+    {.nr = 9, .gpio = -1, .dw_base = 0xc505d0},
+    {.nr = 10, .gpio = -1, .dw_base = 0xc50710},
+    {.nr = 44, .gpio = -1, .dw_base = 0xc204f8},
+    {.nr = 45, .gpio = -1, .dw_base = 0xc20500},
+};
+
+
+static int p2sb_get_dwbase_from_nr(unsigned nr)
+{
+    int i;
+    for (i = 0; i < ARRAY_SIZE(g_p2sb_gpio_map); i++) {
+        if (g_p2sb_gpio_map[i].nr == nr) {
+            return g_p2sb_gpio_map[i].dw_base;
+        }
+    }
+
+    C3000_GPIO_DEBUG_ERROR("Not found nr %d dwbase.\n", nr);
+    return -1;
+}
+
+static void p2sb_gpio_set(struct gpio_chip *gpio, unsigned nr, int val)
+{
+	u32 reg_val;
+	struct p2sb_gpio *chip =	container_of(gpio, struct p2sb_gpio, gpio);
+	unsigned long flags;
+    int dw_base;
+
+    spin_lock_irqsave(&chip->spinlock, flags);
+    dw_base = p2sb_get_dwbase_from_nr(nr);
+    if (dw_base < 0) {
+        C3000_GPIO_DEBUG_ERROR("nr %d get dwbase failed %d.\n", nr, dw_base);
+        spin_unlock_irqrestore(&chip->spinlock, flags);
+        return;
+    }
+
+    chip->reg = chip->base + dw_base;
+	reg_val = ioread32(&chip->reg->pad_cfg_dw0);
+	if (val)
+		reg_val |= (1);
+	else
+		reg_val &= ~(1);
+
+	iowrite32(reg_val, &chip->reg->pad_cfg_dw0);
+	spin_unlock_irqrestore(&chip->spinlock, flags);
+    C3000_GPIO_DEBUG_I2CTEST("nr %d chip->reg->pad_cfg_dw0:%p reg_val=0x%x.\n", nr,&chip->reg->pad_cfg_dw0, reg_val);
+}
+
+static int p2sb_gpio_get(struct gpio_chip *gpio, unsigned nr)
+{
+	struct p2sb_gpio *chip =	container_of(gpio, struct p2sb_gpio, gpio);
+    int dw_base;
+    int g_val;
+    unsigned long flags;
+
+    spin_lock_irqsave(&chip->spinlock, flags);
+    dw_base = p2sb_get_dwbase_from_nr(nr);
+    if (dw_base < 0) {
+        C3000_GPIO_DEBUG_ERROR("nr %d get dwbase failed %d.\n", nr, dw_base);
+        spin_unlock_irqrestore(&chip->spinlock, flags);
+        return -1;
+    }
+
+    chip->reg = chip->base + dw_base;
+    //g_val = ioread32(&chip->reg->pad_cfg_dw0) & (1 << 1);
+    g_val = ((ioread32(&chip->reg->pad_cfg_dw0) >> 1) & 0x1);
+    C3000_GPIO_DEBUG_I2CTEST("nr %d chip->reg->pad_cfg_dw0:%p reg_val=0x%x.\n", nr,&chip->reg->pad_cfg_dw0, g_val);
+	C3000_GPIO_DEBUG_VERBOSE("nr %d chip->reg->pad_cfg_dw0:%p reg_val=0x%x.\n", nr,&chip->reg->pad_cfg_dw0, g_val);
+    spin_unlock_irqrestore(&chip->spinlock, flags);
+    
+	return g_val;
+}
+
+static int p2sb_gpio_direction_output(struct gpio_chip *gpio, unsigned nr,
+				     int val)
+{
+	struct p2sb_gpio *chip =	container_of(gpio, struct p2sb_gpio, gpio);
+	u32 reg_val;
+	unsigned long flags;
+    int dw_base;
+
+    spin_lock_irqsave(&chip->spinlock, flags);
+    dw_base = p2sb_get_dwbase_from_nr(nr);
+    if (dw_base < 0) {
+        C3000_GPIO_DEBUG_ERROR("nr %d get dwbase failed %d.\n", nr, dw_base);
+        spin_unlock_irqrestore(&chip->spinlock, flags);
+        return -1;
+    }
+
+    chip->reg = chip->base + dw_base;
+	reg_val = ioread32(&chip->reg->pad_cfg_dw0);
+    reg_val &= ~C3000_P2SB_DW0_PMODE_MASK;
+    reg_val &= ~C3000_P2SB_DW0_TX_EN_MASK;
+    reg_val |= C3000_P2SB_DW0_RX_EN_MASK;
+	if (val)
+		reg_val |= (1);
+	else
+		reg_val &= ~(1);
+	iowrite32(reg_val, &chip->reg->pad_cfg_dw0);
+	spin_unlock_irqrestore(&chip->spinlock, flags);
+    C3000_GPIO_DEBUG_I2CTEST("nr %d val %d chip->reg->pad_cfg_dw0:%p reg_val=0x%x.\n", nr, val, &chip->reg->pad_cfg_dw0, reg_val);
+	return 0;
+}
+
+static int p2sb_gpio_direction_input(struct gpio_chip *gpio, unsigned nr)
+{
+	struct p2sb_gpio *chip =	container_of(gpio, struct p2sb_gpio, gpio);
+	unsigned long flags;
+    u32 reg_val;
+    int dw_base;
+
+    spin_lock_irqsave(&chip->spinlock, flags);
+    dw_base = p2sb_get_dwbase_from_nr(nr);
+    if (dw_base < 0) {
+        C3000_GPIO_DEBUG_ERROR("nr %d get dwbase failed %d.\n", nr, dw_base);
+        spin_unlock_irqrestore(&chip->spinlock, flags);
+        return -1;
+    }
+
+    chip->reg = chip->base + dw_base;
+    C3000_GPIO_DEBUG_I2CTEST("nr %d dwbase 0x%x chip->reg %p chip->reg->pad_cfg_dw0:%p.\n", nr, dw_base, chip->reg, &chip->reg->pad_cfg_dw0);
+
+	reg_val = ioread32(&chip->reg->pad_cfg_dw0);
+    reg_val &= ~C3000_P2SB_DW0_PMODE_MASK;
+	reg_val &= ~C3000_P2SB_DW0_RX_EN_MASK;
+    reg_val |= C3000_P2SB_DW0_TX_EN_MASK;
+	iowrite32(reg_val, &chip->reg->pad_cfg_dw0);
+	spin_unlock_irqrestore(&chip->spinlock, flags);
+    
+    C3000_GPIO_DEBUG_I2CTEST("nr %d chip->reg->pad_cfg_dw0:%p reg_val=0x%x.\n", nr,&chip->reg->pad_cfg_dw0, reg_val);
+
+	return 0;
+}
