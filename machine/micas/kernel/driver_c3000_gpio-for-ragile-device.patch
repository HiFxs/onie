+static void p2sb_gpio_setup(struct p2sb_gpio *chip)
+{
+	struct gpio_chip *gpio = &chip->gpio;
+
+    C3000_GPIO_DEBUG_VERBOSE("Enter dev_name(chip->dev): %s.\n", dev_name(chip->dev));
+	gpio->label = dev_name(chip->dev);
+	gpio->dev = chip->dev;
+	gpio->owner = THIS_MODULE;
+	gpio->direction_input = p2sb_gpio_direction_input;
+	gpio->get = p2sb_gpio_get;
+	gpio->direction_output = p2sb_gpio_direction_output;
+	gpio->set = p2sb_gpio_set;
+	gpio->dbg_show = NULL;
+	gpio->base = 0;
+	gpio->ngpio = C3000_GPIO_PINS_NUMS;
+	gpio->can_sleep = false;
+	gpio->to_irq = NULL;/*p2sb_gpio_to_irq;*/
+    
+}
+
+static int p2sb_gpio_probe(struct pci_dev *pdev,
+				    const struct pci_device_id *id)
+{
+	s32 ret, ret2;
+	struct p2sb_gpio *chip;
+
+    C3000_GPIO_DEBUG_VERBOSE("Enter.\n");
+	chip = kzalloc(sizeof(*chip), GFP_KERNEL);
+	if (chip == NULL) {
+        C3000_GPIO_DEBUG_ERROR("kzalloc failed.\n");
+		return -ENOMEM;
+    }
+
+    C3000_GPIO_DEBUG_VERBOSE("Begin to call pci_enable_device.\n");
+	chip->dev = &pdev->dev;
+	ret = pci_enable_device(pdev);
+	if (ret) {
+		dev_err(&pdev->dev, "%s : pci_enable_device FAILED", __func__);
+		goto err_pci_enable;
+	}
+
+/*	ret = pci_request_regions(pdev, KBUILD_MODNAME);
+	if (ret) {
+		dev_err(&pdev->dev, "pci_request_regions FAILED-%d", ret);
+		goto err_request_regions;
+	}*/
+
+	chip->base = pci_iomap(pdev, 0, 0);
+	if (!chip->base) {
+		dev_err(&pdev->dev, "%s : pci_iomap FAILED", __func__);
+		ret = -ENOMEM;
+		goto err_iomap;
+	}
+    C3000_GPIO_DEBUG_VERBOSE("chip->base 0x%p.\n", chip->base);
+	chip->reg = chip->base;
+	pci_set_drvdata(pdev, chip);
+	spin_lock_init(&chip->spinlock);
+	p2sb_gpio_setup(chip);
+    C3000_GPIO_DEBUG_VERBOSE("Begin to call gpiochip_add.\n");
+	ret = gpiochip_add(&chip->gpio);
+	if (ret) {
+		dev_err(&pdev->dev, "p2sb gpio: Failed to register GPIO ret %d.\n", ret);
+		goto err_gpiochip_add;
+	}
+
+#if 0
+	/* 挂接GPIO信息到GPIO框架 */
+    gpiod_add_lookup_table(&gpio_i2c_gpiod_table);
+    C3000_GPIO_DEBUG_ERROR("After gpiod_add_lookup_table.\n");
+
+    C3000_GPIO_DEBUG_VERBOSE("Begin to call platform_device_register.\n");
+    ret = platform_device_register(&i2c_gpio);
+    C3000_GPIO_DEBUG_VERBOSE("Begin to call platform_device_register ret %d.\n", ret);
+    if (ret) {
+        dev_err(&pdev->dev, "p2sb gpio: Failed to register i2c_gpio ret %d.\n", ret);
+        goto i2c_reg_adapter_err;
+    }
+#else
+    ret = platform_device_register(&i2c_gpio);
+    if (ret < 0) {
+        C3000_GPIO_DEBUG_ERROR("platform_device_register register i2c gpio fail(%d).\n", ret);
+        goto i2c_reg_adapter_err;
+    }
+#endif
+
+    C3000_GPIO_DEBUG_VERBOSE("GET REG[0xC20500]=0X%X", ioread32(chip->base + 0xC20500));
+    C3000_GPIO_DEBUG_VERBOSE("Finish p2sb_gpio_probe.\n");
+	return 0;
+
+
+i2c_reg_adapter_err:
+    gpiochip_remove(&chip->gpio);
+
+err_gpiochip_add:
+	pci_iounmap(pdev, chip->base);
+
+err_iomap:
+	pci_release_regions(pdev);
+
+err_request_regions:
+	pci_disable_device(pdev);
+
+err_pci_enable:
+	kfree(chip);
+	dev_err(&pdev->dev, "%s Failed returns %d\n", __func__, ret);
+	return ret;
+}
+
+static void p2sb_gpio_remove(struct pci_dev *pdev)
+{
+	int err;
+	struct p2sb_gpio *chip = pci_get_drvdata(pdev);
+
+	gpiochip_remove(&chip->gpio);
+	pci_iounmap(pdev, chip->base);
+	pci_release_regions(pdev);
+	pci_disable_device(pdev);
+	kfree(chip);
+}
+
+#define PCI_VENDOR_ID_C3000_P2SB             0x19dd
+static const struct pci_device_id p2sb_gpio_pcidev_id[] = {
+	{ PCI_DEVICE(PCI_VENDOR_ID_INTEL, PCI_VENDOR_ID_C3000_P2SB) },
+	{ 0, }
+};
+MODULE_DEVICE_TABLE(pci, p2sb_gpio_pcidev_id);
+
+static struct pci_driver p2sb_gpio_driver = {
+	.name = "p2sb_gpio",
+	.id_table = p2sb_gpio_pcidev_id,
+	.probe = p2sb_gpio_probe,
+	.remove = p2sb_gpio_remove,
+};
+
+module_pci_driver(p2sb_gpio_driver);
